# ─── System Mode ────────────────────────────────────────────
# Options: "local" (GDPR-safe, Ollama + local Weaviate) or "cloud" (GPT-4o-mini + Weaviate Cloud)
SYSTEM_MODE=local

# ─── OpenAI (Cloud Mode) ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ─── Ollama (Local Mode) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Weaviate ──────────────────────────────────────────────
# Local mode
WEAVIATE_LOCAL_URL=http://localhost:8080
WEAVIATE_GRPC_PORT=50051
# Cloud mode
WEAVIATE_CLOUD_URL=https://your-cluster.weaviate.network
WEAVIATE_CLOUD_API_KEY=your-weaviate-api-key

# ─── Embedding (Cloud) ────────────────────────────────────
OPENAI_EMBED_MODEL=text-embedding-3-small

# ─── Slack Integration ────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ─── Teams Integration ───────────────────────────────────
TEAMS_WEBHOOK_URL=https://your-teams-webhook-url

# ─── Server ──────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
